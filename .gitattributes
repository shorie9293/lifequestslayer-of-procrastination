# CRLF正規化 — 全てのテキストファイルをLFに統一
* text=auto

# Dart/Flutter
*.dart text eol=lf
*.yaml text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.toml text eol=lf

# バイナリ
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.keystore binary
*.jks binary
*.xlsx binary
*.lock binary
